# =============================================
# JARVIS VOICE CONTROLLED AI FACTORY
# Configuration
# =============================================

# Server
PORT=4000

# OpenAI (optional — for enhanced STT via Realtime API)
# The app uses Web Speech API by default.
# To enable OpenAI Realtime API fallback, set:
# OPENAI_API_KEY=sk-proj-...

# Hermes Agent integration (production)
# When Hermes Agent API is available, uncomment:
# HERMES_API_URL=http://localhost:5000
# HERMES_API_KEY=your-hermes-api-key

# Task queue
# MAX_CONCURRENT_TASKS=3
